pipeline {
    agent any
    
    triggers {
        githubPush()
    }
    
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build & Test') {
            steps {
                sh './mvnw clean test'
            }
        }
    }
    
    post {
        success {
            echo 'Pipeline exitoso'
            sh """
            curl -H "Content-Type: application/json" \
            -X POST \
            -d '{"content": "🟢 Pipeline exitoso en rama ${env.GIT_BRANCH}"}' \
            https://discord.com/api/webhooks/1507006234174427307/2WHuLCJB_7NR_-ixH4SAK8QYOflPVbXkMSFV_Phe_n2gmP3Hgw-FA6brvMhOA35yk576
            """
        }
        failure {
            echo 'Pipeline falló'
            sh """
            curl -H "Content-Type: application/json" \
            -X POST \
            -d '{"content": "🔴 Pipeline falló en rama ${env.GIT_BRANCH}"}' \
            https://discord.com/api/webhooks/1507006234174427307/2WHuLCJB_7NR_-ixH4SAK8QYOflPVbXkMSFV_Phe_n2gmP3Hgw-FA6brvMhOA35yk576
            """
        }
    }
}